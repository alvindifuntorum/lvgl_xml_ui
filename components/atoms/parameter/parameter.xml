<component>
	<api>
		<prop name="title" type="string" default="Parameter" />
		<prop name="icon" type="image" default="icon_temperature" />
		<prop name="parameter" type="string" default="--" />
	</api>
	<styles>
		<style
			name="style_base"
			width="100%"
			height="content"
			layout="flex"
			flex_flow="row"
			flex_main_place="center"
			flex_cross_place="center"
			shadow_color="0x000"
			shadow_offset_y="2"
			shadow_opa="30"
			shadow_spread="1"
			shadow_width="#unit_sm"
		/>
	</styles>
	<view>
		<remove_style_all />
		<style name="style_base" />
		<icon_button icon="$icon" />
		<lv_label text="$title" style_flex_grow="1" />
		<lv_label name="subtitle" text="" />
		<lv_switch name="toggle" />
	</view>
</component>
