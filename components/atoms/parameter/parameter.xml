<component>
	<previews>
		<preview style_pad_all="4" />
	</previews>
	<api>
		<prop name="title" type="string" default="Parameter" />
		<prop name="icon" type="image" default="icon_heart" />
		<prop name="parameter" type="string" default="--" />
	</api>
	<styles>
		<style
			name="style_base"
			width="100%"
			height="content"
			layout="flex"
			pad_all="#unit_md"
			flex_flow="row"
			flex_main_place="space_between"
			flex_cross_place="center"
			radius="#unit_sm"
			shadow_color="0x000"
			shadow_offset_y="4"
			shadow_opa="64"
			shadow_spread="0"
			shadow_width="2"
		/>
		<style
			name="style_left"
			height="content"
			width="content"
			layout="flex"
			flex_flow="row"
			flex_cross_place="center"
			pad_column="#unit_sm"
		/>
		<style
			name="style_right"
			height="content"
			width="content"
			layout="flex"
			flex_flow="row"
			flex_cross_place="center"
			flex_main_place="end"
			pad_column="#unit_sm"
		/>

		<!-- Switch: rectangular track (radius/md=8) and knob (radius/sm=4), matching Figma "Input / Toggle" -->
		<style
			name="style_switch_main"
			radius="10"
			bg_color="#surface_primary_light"
			bg_opa="0%"
			border_width="2"
			border_color="0x000"
		/>
		<style name="style_switch_main_dark" bg_color="#surface_primary_dark" />
		<style
			name="style_switch_indicator"
			radius="8"
			bg_color="#surface_primary_light"
			border_width="0"
			bg_opa="100%"
		/>
		<style name="style_switch_indicator_dark" bg_color="#surface_primary_dark" />
		<style
			name="style_switch_knob"
			radius="4"
			pad_top="-6"
			pad_bottom="-6"
			pad_left="-6"
			pad_right="-6"
			shadow_opa="0"
			bg_color="0x000"
			border_width="0"
		/>
		<style name="style_switch_knob_checked" bg_color="#bg_primary_light" bg_opa="100%" />
		<style name="style_switch_knob_dark" bg_color="0x000" />
		<style name="style_switch_knob_checked_dark" bg_color="#bg_primary_dark" />
	</styles>
	<view>
		<remove_style_all />
		<style name="style_base" />
		<lv_obj>
			<remove_style_all />
			<style name="style_left" />
			<icon_button icon="$icon" />
			<lv_label text="$title" />
		</lv_obj>
		<lv_obj>
			<remove_style_all />
			<style name="style_right" />
			<lv_label name="parameter_label" text="$parameter" />
			<lv_switch name="toggle" width="44" height="34">
				<style name="style_switch_main" selector="main" />
				<style name="style_switch_indicator" selector="indicator|checked" />
				<style name="style_switch_knob" selector="knob" />
				<style name="style_switch_knob_checked" selector="knob|checked" />
				<!--bind_style subject="dark_theme" ref_value="1" name="style_switch_main_dark" selector="main" />
				<bind_style
					subject="dark_theme"
					ref_value="1"
					name="style_switch_indicator_dark"
					selector="indicator|checked"
				/>
				<bind_style subject="dark_theme" ref_value="1" name="style_switch_knob_dark" selector="knob" />
				<bind_style
					subject="dark_theme"
					ref_value="1"
					name="style_switch_knob_checked_dark"
					selector="knob|checked"
				/-->
			</lv_switch>
		</lv_obj>
	</view>
</component>
