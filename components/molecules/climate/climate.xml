<!--
 Climate component XML definition.
 -->
<component>
	<previews>
		<preview height="480" />
	</previews>
	<styles>
		<style
			name="style_base"
			width="100%"
			height="100%"
			flex_grow="1"
			layout="flex"
			flex_flow="column"
			flex_cross_place="center"
		/>

		<style
			name="control_arc"
			flex_grow="1"
			layout="flex"
			flex_flow="column"
			flex_cross_place="center"
			flex_main_place="center"
		/>

		<style name="content_arc" width="100%" flex_grow="1" pad_all="10" />

		<style name="background_arc_indicator" arc_color="0x0BBCF6" arc_width="6" arc_rounded="true" pad_all="4" />
		<style
			name="background_arc_knob"
			bg_opa="100%"
			bg_color="0xfff"
			border_color="0x000"
			border_width="1"
			pad_all="2"
			shadow_color="0x312e81"
			shadow_width="10"
			shadow_opa="160"
		/>

		<style name="control_arc_indicator" arc_color="0x929293" arc_width="6" arc_rounded="true" pad_all="4" />
		<style
			name="control_arc_knob"
			bg_opa="100%"
			bg_color="0xfff"
			border_color="0x000"
			border_width="1"
			pad_all="2"
			shadow_color="0x312e81"
			shadow_width="10"
			shadow_opa="160"
		/>

		<style
			name="control_row"
			width="100%"
			pad_column="10"
			pad_bottom="30"
			flex_cross_place="center"
			flex_main_place="center"
		/>
	</styles>

	<view>
		<remove_style_all />
		<style name="style_base" />

		<zone />

		<lv_obj>
			<remove_style_all />
			<style name="content_arc" />

			<lv_arc width="100%" height="100%" mode="reverse" value="50" disabled="true">
				<!-- Internal temperature arc -->
				<style name="background_arc_indicator" selector="indicator" />
				<style name="background_arc_knob" selector="knob" />
			</lv_arc>

			<lv_arc width="100%" height="100%" style_arc_opa="0">
				<!-- Target temperature arc -->
				<style name="control_arc" />
				<!--style name="control_arc_knob" selector="knob" /-->

				<style name="control_arc_indicator" selector="indicator" />
				<style name="control_arc_knob" selector="knob" />

				<row width="100%" style_flex_main_place="center" style_pad_bottom="30">
					<lv_image src="icon_cloudy" style_pad_right="20" />
					<lv_label name="internal_temp_label" text="27" align="center" style_text_font="gibson_40" />
					<lv_label text="°C" align="center" style_text_font="gibson_40" />
				</row>
				<row width="100%" style_flex_main_place="center" style_pad_bottom="30">
					<lv_image src="icon_cloudy" />
					<lv_label name="target_temp_label" text="21" style_text_font="gibson_80" />
					<lv_label text="°C" style_text_font="gibson_20" />
				</row>
				<row width="100%" style_flex_main_place="center" style_pad_column="10">
					<lv_image name="img_sleep" src="icon_cloudy" />
					<lv_image name="img_smarteco" src="icon_cloudy" />
				</row>
			</lv_arc>
		</lv_obj>

		<row scrollable="false">
			<style name="control_row" />
			<icon_label_button name="mode_button" label="Mode" icon="icon_cooling" width="45%" />
			<icon_label_button name="fanspeed_button" label="Fan" icon="icon_fan" width="45%" />
		</row>
	</view>
</component>
