<!-- figma_node_id="548:5405" -->
<component>
	<previews>
		<preview width="390" height="400" />
	</previews>

	<api>
		<prop name="zone_name" type="string" default="Bedroom" />
		<prop name="mode_icon" type="image" default="icon_heart" />
		<prop name="mode_label" type="string" default="Cooling" />
		<prop name="fanspeed_icon" type="image" default="icon_heart" />
		<prop name="fanspeed_label" type="string" default="Medium" />
	</api>

	<styles>
		<style
			name="style_base"
			width="100%"
			height="100%"
			layout="flex"
			flex_flow="column"
			flex_main_place="center"
			flex_cross_place="center"
			pad_all="0"
			bg_opa="0"
			border_width="0"
		/>

		<!-- Header container: flex column, 4px top padding -->
		<style
			name="style_header"
			width="100%"
			height="content"
			layout="flex"
			flex_flow="column"
			flex_main_place="center"
			flex_cross_place="center"
			pad_top="4"
			pad_bottom="0"
			pad_left="0"
			pad_right="0"
			bg_opa="0"
			border_width="0"
		/>

		<!-- Nav row: left arrow / zone name / right arrow, 40px tall, 32px side padding -->
		<style
			name="style_nav_row"
			width="100%"
			height="40"
			layout="flex"
			flex_flow="row"
			flex_main_place="space_between"
			flex_cross_place="center"
			pad_left="32"
			pad_right="32"
			pad_top="0"
			pad_bottom="0"
			bg_opa="0"
			border_width="0"
		/>

		<!-- Arrow navigation buttons: 40x40, transparent -->
		<style
			name="style_nav_btn"
			width="40"
			height="40"
			layout="flex"
			flex_main_place="center"
			flex_cross_place="center"
			bg_opa="0"
			border_width="0"
			shadow_opa="0"
			pad_all="0"
		/>

		<!-- Zone name: Gibson 20px, dark text -->
		<style name="style_zone_name" text_font="gibson_20" text_color="0x333333" />

		<!-- Pagination dots row -->
		<style
			name="style_pagination_row"
			width="content"
			height="content"
			layout="flex"
			flex_flow="row"
			flex_main_place="center"
			flex_cross_place="center"
			pad_column="4"
			bg_opa="0"
			border_width="0"
		/>

		<!-- Active pagination dot: 16x4, dark -->
		<style
			name="style_dot_active"
			width="16"
			height="4"
			radius="2"
			bg_color="0x333333"
			bg_opa="100%"
			border_width="0"
		/>

		<!-- Inactive pagination dot: 8x2, neutral gray -->
		<style
			name="style_dot_inactive"
			width="8"
			height="2"
			radius="2"
			bg_color="0x929293"
			bg_opa="100%"
			border_width="0"
		/>

		<!-- Arc track (gray unfilled background) -->
		<style name="style_arc_main" arc_width="12" arc_color="0xD0D0D0" />

		<!-- Arc indicator (blue filled portion) -->
		<style name="style_arc_indicator" arc_width="12" arc_color="0x45AFDB" />

		<!-- Arc knob: colored dot at end of indicator -->
		<style name="style_arc_knob" pad_all="4" bg_color="0x45AFDB" border_width="0" />

		<!-- Room temperature label: "27°C", neutral gray, body-xl -->
		<style name="style_room_temp" text_font="gibson_22" text_color="0x929293" />

		<!-- Target temperature number: "21", large, dark, h0 -->
		<style name="style_target_temp" text_font="gibson_60" text_color="0x333333" />

		<!-- Temperature unit suffix: "°C", neutral gray, body-lg -->
		<style name="style_temp_unit" text_font="gibson_18" text_color="0x929293" />
	</styles>

	<view>
		<remove_style_all />
		<style name="style_base" />

		<zone />

		<!-- ── Temperature arc: 270° sweep, gap at bottom ── -->
		<lv_arc
			name="target_temp_arc"
			bind_value="thermostat_temp"
			min_value="16"
			max_value="31"
			width="100%"
			height="content"
			bg_start_angle="135"
			bg_end_angle="45"
			start_angle="135"
			flex_grow="1"
		>
			<style name="style_arc_main" selector="main" />
			<style name="style_arc_indicator" selector="indicator" />
			<style name="style_arc_knob" selector="knob" />

			<!-- Centered content column inside the arc -->
			<column
				name="arc_content"
				style_width="content"
				style_height="content"
				style_flex_main_place="center"
				style_flex_cross_place="center"
				style_pad_row="#unit_xl"
				align="center"
			>
				<!-- Room temperature row: thermometer icon + "27°C" -->
				<row
					name="room_temp_row"
					style_flex_main_place="center"
					style_flex_cross_place="center"
					style_pad_column="#unit_2xs"
				>
					<lv_image name="thermometer_icon" src="icon_heart" />
					<lv_label name="room_temp_label" bind_text="room_temp" bind_text-fmt="%d°C">
						<style name="style_room_temp" />
					</lv_label>
				</row>

				<!-- Target temperature row: adjust icon + "21" + "°C" -->
				<row name="target_temp_row" style_flex_main_place="center" style_flex_cross_place="center">
					<lv_image name="temp_adjust_icon" src="icon_heart" style_width="20" style_height="20" />
					<lv_label name="target_temp_label" bind_text="thermostat_temp" bind_text-fmt="%d">
						<style name="style_target_temp" />
					</lv_label>
					<lv_label name="temp_unit_label" text="°C">
						<style name="style_temp_unit" />
					</lv_label>
				</row>

				<!-- Mode indicator icons: sleep + eco -->
				<row
					name="mode_icons_row"
					style_flex_main_place="center"
					style_flex_cross_place="center"
					style_pad_column="#unit_sm"
				>
					<lv_image name="sleep_icon" src="icon_heart" />
					<lv_image name="eco_icon" src="icon_heart" />
				</row>
			</column>
		</lv_arc>

		<!-- ── Bottom: mode and fan-speed pill buttons ── -->
		<row
			name="bottom_buttons"
			height="100%"
			style_height="52"
			style_flex_main_place="center"
			style_flex_cross_place="center"
			style_pad_all="10"
			style_pad_column="10"
		>
			<icon_label_button name="mode_button" icon="$mode_icon" label="$mode_label" />
			<icon_label_button name="fanspeed_button" icon="$fanspeed_icon" label="$fanspeed_label" />
		</row>
	</view>
</component>
