<!--
 Climate / Zone component XML definition.
 figma_node_id="548:5405"
 -->
<component>
        <api>
                <prop name="zone1_name"     type="string" default="Bedroom" />
                <prop name="zone2_name"     type="string" default="Living Room" />
                <prop name="zone3_name"     type="string" default="Kitchen" />
                <prop name="zone4_name"     type="string" default="Bathroom" />
                <prop name="zone5_name"     type="string" default="Office" />
                <prop name="mode_icon"     type="image"  default="icon_heart" />
                <prop name="mode_label"    type="string" default="Cooling" />
                <prop name="fanspeed_icon" type="image"  default="icon_heart" />
                <prop name="fanspeed_label" type="string" default="Medium" />
        </api>

        <styles>
                <style name="style_base"
                        width="100%"
                        height="100%"
                        flex_grow="1"
                        layout="flex"
                        flex_flow="column"
                        flex_main_place="center"
                        flex_cross_place="center"
                        shadow_color="0x000"
                        shadow_offset_y="2"
                        shadow_opa="30"
                        shadow_spread="1"
                        shadow_width="#unit_sm"
                        />

                <style name="style_room_temp"
                        text_font="geist_regular_32"
                        text_color="0x929293"
                        />

                <style name="style_target_temp"
                        text_font="geist_light_60"
                        text_color="0x333333"
                        />

                <style name="style_temp_unit"
                        text_font="geist_regular_14"
                        text_color="0x929293"
                        />

                <style name="style_arc_indicator"
                        arc_width="12"
                        arc_color="0x45AFDB"
                        />

                <style name="style_arc_main"
                        arc_width="12"
                        arc_color="0xD0D0D0"
                        />
        </styles>

        <view>
                <remove_style_all />
                <style name="style_base" />

                <!-- Zone header: tab view for navigating between zones -->
                <lv_tabview name="zone_header"
                        style_width="100%"
                        tab_pos="top"
                        tab_header_height="40"
                        >
                        <lv_tab name="tab_zone1" text="$zone1_name" />
                        <lv_tab name="tab_zone2" text="$zone2_name" />
                        <lv_tab name="tab_zone3" text="$zone3_name" />
                        <lv_tab name="tab_zone4" text="$zone4_name" />
                        <lv_tab name="tab_zone5" text="$zone5_name" />
                </lv_tabview>

                <!-- Temperature arc -->
                <lv_arc
                        name="target_temp_arc"
                        bind_value="thermostat_temp"
                        min_value="16"
                        max_value="31"
                        width="86%"
                        height="68%"
                        align="center"
                        >
                        <style name="style_arc_indicator" selector="indicator" />
                        <style name="style_arc_main" selector="main" />

                        <column name="arc_content"
                                style_width="content"
                                style_height="content"
                                style_flex_main_place="center"
                                style_flex_cross_place="center"
                                style_pad_row="#unit_xl"
                                align="center"
                                >
                                <!-- Room temperature -->
                                <row name="room_temp_row"
                                        style_flex_main_place="center"
                                        style_flex_cross_place="center"
                                        style_pad_column="#unit_sm"
                                        >
                                        <lv_image name="thermometer_icon" src="icon_heart" />
                                        <lv_label name="room_temp_label"
                                                bind_text="room_temp"
                                                bind_text-fmt="%d°C"
                                                >
                                                <style name="style_room_temp" />
                                        </lv_label>
                                </row>

                                <!-- Target temperature -->
                                <row name="target_temp_row"
                                        style_flex_main_place="center"
                                        style_flex_cross_place="center"
                                        >
                                        <lv_image name="temp_adjust_icon" src="icon_heart" />
                                        <lv_label name="target_temp_label"
                                                bind_text="thermostat_temp"
                                                bind_text-fmt="%d"
                                                >
                                                <style name="style_target_temp" />
                                        </lv_label>
                                        <lv_label name="temp_unit_label" text="°C">
                                                <style name="style_temp_unit" />
                                        </lv_label>
                                </row>

                                <!-- Sleep / eco mode indicators -->
                                <row name="mode_icons_row"
                                        style_flex_main_place="center"
                                        style_flex_cross_place="center"
                                        style_pad_column="#unit_sm"
                                        >
                                        <lv_image name="sleep_icon" src="icon_heart" />
                                        <lv_image name="eco_icon" src="icon_heart" />
                                </row>
                        </column>
                </lv_arc>

                <!-- Mode and fan speed buttons -->
                <row name="bottom_buttons"
                        style_flex_main_place="center"
                        style_flex_cross_place="center"
                        style_pad_column="#unit_sm"
                        >
                        <icon_label_button name="mode_button"     icon="$mode_icon"     label="$mode_label" />
                        <icon_label_button name="fanspeed_button" icon="$fanspeed_icon" label="$fanspeed_label" />
                </row>
        </view>
</component>
