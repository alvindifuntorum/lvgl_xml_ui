<component>
	<previews>
		<preview height="480" width="1024" />
	</previews>
	<styles>
		<style name="style_base" width="100%" height="100%" layout="flex" flex_flow="row" pad_all="5" pad_column="5" />

		<style
			name="info_header_label"
			width="100%"
			text_font="gibson_24_semibold"
			pad_bottom="5"
			border_color="0x333"
			border_opa="50%"
			border_width="1"
			border_side="bottom"
		/>
		<style name="info_content_text" width="100%" flex_grow="1" text_align="center" pad_all="10" />
		<style
			name="pagination_row"
			height="content"
			flex_grow="1"
			flex_main_place="center"
			flex_cross_place="center"
			pad_column="4"
		/>

		<!-- Active pagination dot: 16x4, dark -->
		<style
			name="style_dot_active"
			width="16"
			height="4"
			radius="2"
			bg_color="0x333333"
			bg_opa="100%"
			border_width="0"
		/>

		<!-- Inactive pagination dot: 8x2, neutral gray -->
		<style
			name="style_dot_inactive"
			width="8"
			height="2"
			radius="2"
			bg_color="0x929293"
			bg_opa="100%"
			border_width="0"
		/>
		<style name="notification_column" flex_grow="1" height="100%" pad_row="2" />
	</styles>
	<view>
		<remove_style_all />
		<style name="style_base" />

		<!-- Left side -->
		<row style_flex_grow="1" style_height="100%">
			<column style_height="100%" style_flex_grow="1">
				<!-- Notificaion information -->
				<column style_width="100%" style_flex_grow="1">
					<lv_label text="E0: Communication Failure">
						<style name="info_header_label" />
					</lv_label>
					<lv_textarea
						text_selection="false"
						text="Description. Lorem ipsum dolor sit amet, consectetur adipiscing elit. Nunc quis magna felis. Cras laoreet rutrum velit, a suscipit nulla eleifend sit amet. Praesent sagittis rutrum consequat."
					>
						<remove_style_all />
						<style name="info_content_text" />
					</lv_textarea>
				</column>

				<!-- Bottom pagination row -->
				<row width="100%" style_flex_main_place="center" style_flex_cross_place="center">
					<icon_button />

					<row>
						<style name="pagination_row" />
						<lv_obj name="dot1">
							<remove_style_all />
							<style name="style_dot_active" />
						</lv_obj>
						<lv_obj name="dot2">
							<remove_style_all />
							<style name="style_dot_inactive" />
						</lv_obj>
						<lv_obj name="dot3">
							<remove_style_all />
							<style name="style_dot_inactive" />
						</lv_obj>
					</row>

					<icon_button />
				</row>
			</column>
		</row>

		<!-- Right side -->
		<column>
			<style name="notification_column" />
			<notification_info />
			<notification_info />
			<notification_info />
			<notification_info />
			<notification_info />
			<notification_info />
			<notification_info />
		</column>
	</view>
</component>
